{
  "name": "@coderef/CODEREF-CORE",
  "version": "2.0.0",
  "description": "Core scanning and parsing library for CodeRef system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "validate-routes": "./dist/src/cli/validate-routes.js",
    "scan-frontend-calls": "./dist/src/cli/scan-frontend-calls.js",
    "populate-coderef": "./dist/src/cli/populate.js",
    "coderef-scan": "./dist/src/cli/scan.js",
    "rag-index": "./dist/src/cli/rag-index.js",
    "rag-search": "./dist/src/cli/rag-search.js",
    "rag-status": "./dist/src/cli/rag-status.js",
    "coderef-pipeline": "./dist/src/cli/coderef-pipeline.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./search-client": {
      "types": "./dist/src/search-client.d.ts",
      "default": "./dist/src/search-client.js"
    }
  },
  "scripts": {
    "build": "npx tsc && npm run build:cli",
    "build:cli": "npx tsc -p tsconfig.cli.json",
    "dev": "npx tsc --watch",
    "clean": "rimraf dist",
    "test": "npx vitest",
    "test:watch": "npx vitest --watch",
    "test:coverage": "npx vitest --coverage",
    "test:ui": "npx vitest --ui"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@pinecone-database/pinecone": "^2.0.0",
    "acorn": "^8.15.0",
    "chromadb": "^1.8.0",
    "chokidar": "^3.5.3",
    "glob": "^11.0.3",
    "minimatch": "^10.0.3",
    "openai": "^4.0.0",
    "protobufjs": "^8.0.1",
    "tiktoken": "^1.0.12",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.1.12"
  }
}
