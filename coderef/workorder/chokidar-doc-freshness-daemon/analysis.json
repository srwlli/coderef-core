  "risks": [
    {
      "id": "R1",
      "title": "Debounce window thrash on bulk file ops (rebase, npm install, branch switch)",
      "likelihood": "medium",
      "impact": "medium",
      "mitigation": "Cap regen run at 1 per 30s window even if events keep arriving; add upper-bound flush rate; document expected behavior on bulk events"
    },
    {
      "id": "R2",
      "title": "Heartbeat partial-write corrupting LLOYD pre-prompt reads",
      "likelihood": "low",
      "impact": "high",
      "mitigation": "Atomic temp+rename pattern (Phase 3 explicit). LLOYD-side: try/except around JSON parse; degrade to no-freshness if corrupt"
    },
    {
      "id": "R3",
      "title": "Daemon process crash leaves stale heartbeat that LLOYD treats as fresh",
      "likelihood": "medium",
      "impact": "medium",
      "mitigation": "Heartbeat carries process_pid + alive_at. LLOYD checks alive_at age; if > N min, treat as stale despite last_scan_at value"
    },
    {
      "id": "R4",
      "title": "chokidar event loss on Windows FS-watcher recursive depth",
      "likelihood": "medium",
      "impact": "medium",
      "mitigation": "Document known chokidar Windows quirks in deployment doc; recommend usePolling fallback flag for paths > N depth"
    },
    {
      "id": "R5",
      "title": "Prerequisite WO-PHASE-6-CLOSE-GATE-UNIVERSAL-001 has not shipped, daemon double-fires regen with Phase 6 close",
      "likelihood": "low",
      "impact": "low",
