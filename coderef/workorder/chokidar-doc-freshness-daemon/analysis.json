    },
    {
      "id": "D2",
      "choice": "30-second debounce window (not configurable in v1)",
      "rationale": "LLOYD D2 spec specifies 30s; reduces churn under bulk file ops; can add --debounce-ms flag in v1.1 if needed"
    },
    {
      "id": "D3",
      "choice": "Atomic write via temp+rename (not in-place fs.writeFile)",
      "rationale": "LLOYD reads heartbeat on every request; partial writes would corrupt pre-prompt assembly"
    },
